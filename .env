# DebugAI — AI Provider Configuration
# Copy this file to .env and fill in your key
# Only ONE key is needed — DebugAI auto-detects which provider to use

# ── Option 1: OpenAI (recommended) ──────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Option 2: Anthropic ──────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Option 3: NVIDIA ─────────────────────────────────────────────────────────
# Get your key at: https://integrate.api.nvidia.com/
NVIDIA_API_KEY=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

# ── Auto-detection order ─────────────────────────────────────────────────────
# OpenAI → Anthropic → NVIDIA
# The first key that is set will be used automatically.
# Override with: debuai error.log --ai --provider anthropic